<script>
// 平滑导航
document.querySelectorAll('.nav a').forEach(link=>{
  link.addEventListener('click', function(e){
    const targetId = this.getAttribute('href');
    if(targetId && targetId.startsWith('#')){
      e.preventDefault();
      const target = document.querySelector(targetId);
      if(target){
        const y = target.getBoundingClientRect().top + window.pageYOffset - 88;
        window.scrollTo({top:y, behavior:'smooth'});
      }
    }
  });
});

// 鼠标光
const light=document.querySelector(".cursor-light");
const core=document.querySelector(".cursor-core");
let x=0,y=0,tx=0,ty=0;
document.addEventListener("mousemove",e=>{tx=e.clientX;ty=e.clientY;});
function animateCursor(){
  x+=(tx-x)*0.08;
  y+=(ty-y)*0.08;
  if(light && core){
    light.style.left=x+'px'; light.style.top=y+'px';
    core.style.left=x+'px'; core.style.top=y+'px';
  }
  requestAnimationFrame(animateCursor);
}
animateCursor();

// 第二页展开
function toggle(id,data){
  const el=document.getElementById(id);
  if(!el) return;
  el.onclick=function(){
    let next=this.nextElementSibling;
    if(next && next.classList.contains('sub-cards')) {
      next.remove();
    }else{
      const box=document.createElement('div');
      box.className='sub-cards';
      data.forEach(d=>{
        const div=document.createElement('div');
        div.className='sub-card';
        div.innerHTML=`<div class="icon">${d[0]}</div><div class="sub-title">${d[1]}</div>`;
        box.appendChild(div);
      });
      this.parentNode.insertBefore(box,this.nextSibling);
    }
  }
}
toggle('job1',[
  ["⚙️","产品开发与全生命周期管理"],
  ["🎯","市场活动策划与执行"],
  ["📊","市场调研与数据分析"],
  ["📱","新媒体运营与内容创作"]
]);
toggle('job2',[
  ["🧠","问卷设计与逻辑控制"],
  ["👥","样本筛选与讨论执行"],
  ["📍","调研流程跟进与项目协作"],
  ["📝","结论整理与报告支持"]
]);
toggle('job3',[
  ["🎪","主题活动策划"],
  ["📣","传播运营与现场执行"],
  ["🤝","资源协调与对接"],
  ["🎨","视觉物料统筹"]
]);
toggle('job4',[
  ["🏛️","空间与展陈设计"],
  ["🔗","跨团队协作执行"],
  ["🎥","媒体内容策划与视觉"],
  ["🧭","展览导引与解说"]
]);

// 鼠标光颜色切换
window.addEventListener("scroll",()=>{
  const about=document.querySelector(".section");
  if(!about || !light || !core) return;
  const aboutTop=about.offsetTop;
  const projectsTop=document.querySelector(".projects-section").offsetTop;

  if(window.scrollY > aboutTop-220 && window.scrollY < projectsTop-120){
    light.style.background="radial-gradient(circle,rgba(255,255,255,0.34),transparent 70%)";
    core.style.background="radial-gradient(circle,rgba(255,255,255,0.92),transparent 70%)";
  }else{
    light.style.background="radial-gradient(circle,rgba(0,47,167,0.42),transparent 70%)";
    core.style.background="radial-gradient(circle,rgba(0,47,167,0.92),transparent 70%)";
  }
});

// 项目卡片轮换
const slides=document.querySelectorAll('.slide-card');
let current=0;
function updateSlides(){
  slides.forEach((s,i)=>{
    let offset=i-current;
    if(offset > 2) offset -= slides.length;
    if(offset < -2) offset += slides.length;
    let z=10-Math.abs(offset);
    if(z<1) z=1;
    s.style.zIndex=z;
    s.style.left=`calc(50% + ${offset*108}px)`;
    s.style.top='50%';
    s.style.transform=`translate(-50%,-50%) scale(${offset===0?1:0.9}) rotate(${offset* -3.2}deg)`;
    s.style.opacity=Math.abs(offset)>2?0:1;
    s.style.pointerEvents=Math.abs(offset)>2?'none':'auto';
  });
}
slides.forEach(s=>{
  s.addEventListener('mouseenter',()=>{
    current=parseInt(s.dataset.index);
    updateSlides();
  });
});
updateSlides();

document.querySelector('.slide-arrow.left').addEventListener('click',()=>{
  current=(current-1+slides.length)%slides.length;
  updateSlides();
});
document.querySelector('.slide-arrow.right').addEventListener('click',()=>{
  current=(current+1)%slides.length;
  updateSlides();
});

let isDragging=false,startX=0;
const slidesContainer=document.querySelector('.slides-container');
slidesContainer.addEventListener('mousedown',e=>{
  isDragging=true;
  startX=e.clientX;
});
document.addEventListener('mousemove',e=>{
  if(!isDragging) return;
  const dx=e.clientX-startX;
  if(dx>70){
    current=(current-1+slides.length)%slides.length;
    updateSlides();
    startX=e.clientX;
  }else if(dx<-70){
    current=(current+1)%slides.length;
    updateSlides();
    startX=e.clientX;
  }
});
document.addEventListener('mouseup',()=>{isDragging=false;});

let touchStartX=0;
slidesContainer.addEventListener('touchstart',e=>{
  touchStartX=e.touches[0].clientX;
},{passive:true});
slidesContainer.addEventListener('touchmove',e=>{
  const dx=e.touches[0].clientX-touchStartX;
  if(dx>70){
    current=(current-1+slides.length)%slides.length;
    updateSlides();
    touchStartX=e.touches[0].clientX;
  }else if(dx<-70){
    current=(current+1)%slides.length;
    updateSlides();
    touchStartX=e.touches[0].clientX;
  }
},{passive:true});

