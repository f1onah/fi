<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Fiona Huang Portfolio</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  font-family:'Jost',sans-serif;
  background:#fff;
  overflow-x:hidden;
  color:#111;
}
:root{
  --blue:#002FA7;
  --blue-deep:#001b63;
  --blue-light:#4f7dff;
  --white:#fff;
  --text:#111;
  --muted:#6d7893;
  --shadow:0 18px 60px rgba(0,0,0,.14);
}

.nav{
  position:fixed;
  top:22px;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  gap:14px;
  z-index:999;
  padding:10px 14px;
  border-radius:999px;
  background:rgba(255,255,255,.68);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  box-shadow:0 8px 30px rgba(0,47,167,.08);
  border:1px solid rgba(0,47,167,.08);
}
.nav a{
  color:var(--blue);
  text-decoration:none;
  font-size:13px;
  letter-spacing:1.8px;
  padding:9px 14px;
  border-radius:999px;
  transition:.35s ease;
  white-space:nowrap;
}
.nav a:hover{
  background:rgba(0,47,167,.08);
  transform:translateY(-1px);
}

.cursor-light,.cursor-core{
  position:fixed;
  pointer-events:none;
  transform:translate(-50%,-50%);
  z-index:998;
}
.cursor-light{
  width:600px;height:600px;
  background:radial-gradient(circle,rgba(0,47,167,.42),transparent 70%);
  filter:blur(105px);
  transition:background .4s;
}
.cursor-core{
  width:120px;height:120px;
  background:radial-gradient(circle,rgba(0,47,167,.92),transparent 70%);
  transition:background .4s;
}

/* 首页 */
.hero{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  position:relative;
  overflow:hidden;
  padding:100px 24px 40px;
}
.hero-particle-wrap{
  position:relative;
  width:min(96vw,1320px);
  height:540px;
  display:flex;
  align-items:center;
  justify-content:center;
}
#heroParticleCanvas{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  pointer-events:none;
  z-index:1;
}
.title{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  position:absolute;
  inset:0;
  color:var(--blue);
}
.title-main{z-index:4;}
.title-main .title-word{
  display:block;
  font-family:'Sora',sans-serif;
  font-size:clamp(52px,8vw,110px);
  font-weight:800;
  letter-spacing:0.12em;
  line-height:1;
  transition:filter .6s ease, transform .6s ease, opacity .6s ease;
  text-shadow:0 0 1px rgba(0,47,167,.35),0 0 10px rgba(0,47,167,.08);
}
.title-main .sub{
  font-size:18px;
  margin-top:18px;
  letter-spacing:8px;
  transition:opacity .6s ease, transform .6s ease, filter .6s ease;
}
.title-ghost{
  pointer-events:none;
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  color:var(--blue);
  mix-blend-mode:multiply;
}
.title-ghost .title-word{
  font-family:'Sora',sans-serif;
  font-size:clamp(52px,8vw,110px);
  font-weight:800;
  letter-spacing:0.12em;
  line-height:1;
}
.title-ghost .sub{
  font-size:18px;
  margin-top:18px;
  letter-spacing:8px;
}
.title-ghost-1{z-index:2;filter:blur(7px);transform:translate(10px,2px) scale(1.01);opacity:.18;}
.title-ghost-2{z-index:2;filter:blur(18px);transform:translate(-14px,10px) scale(1.045);opacity:.12;}
.title-ghost-3{z-index:2;filter:blur(28px);transform:translate(0,0) scale(1.07);opacity:.08;}
.hero-particle-wrap::before{
  content:"";
  position:absolute;
  width:760px;
  height:760px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(0,47,167,.15), rgba(0,47,167,0) 70%);
  filter:blur(38px);
  z-index:0;
  animation:heroBreath 5s ease-in-out infinite;
}
.hero-particle-wrap::after{
  content:"";
  position:absolute;
  width:980px;
  height:440px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(0,47,167,.06), rgba(0,47,167,0) 72%);
  filter:blur(44px);
  z-index:0;
}
@keyframes heroBreath{
  0%,100%{transform:scale(1) translateY(0);}
  50%{transform:scale(1.08) translateY(-8px);}
}
.hero-particle-wrap.active .title-main .title-word{
  filter:blur(1.8px);
  transform:scale(1.012) translateY(1px);
  opacity:.9;
}
.hero-particle-wrap.active .title-main .sub{
  transform:translateY(2px);
  opacity:.85;
  filter:blur(.6px);
}
.hero-particle-wrap.active .title-ghost-1{transform:translate(22px,-2px) scale(1.04);opacity:.28;}
.hero-particle-wrap.active .title-ghost-2{transform:translate(-26px,14px) scale(1.08);opacity:.16;}
.hero-particle-wrap.active .title-ghost-3{transform:translate(8px,-10px) scale(1.12);opacity:.11;}

/* 海浪 */
.wave-transition{
  position:relative;
  width:100%;
  height:220px;
  background:#fff;
  overflow:hidden;
  margin-top:-30px;
}
.wave-transition svg{position:absolute;bottom:0;width:200%;}
.wave1{fill:#002FA7;animation:waveMove1 8s linear infinite;}
.wave2{fill:#002FA7;opacity:.9;animation:waveMove2 12s linear infinite;}
.wave3{fill:#002FA7;opacity:.8;animation:waveMove3 16s linear infinite;}
@keyframes waveMove1{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
@keyframes waveMove2{0%{transform:translateX(-20px);}100%{transform:translateX(-70px);}}
@keyframes waveMove3{0%{transform:translateX(-40px);}100%{transform:translateX(-90px);}}

/* 第二页 */
.section{
  padding:18px 8% 120px;
  background:
    radial-gradient(circle at 12% 14%, rgba(255,255,255,.12), transparent 22%),
    radial-gradient(circle at 88% 20%, rgba(255,255,255,.08), transparent 18%),
    linear-gradient(180deg, #002FA7 0%, #00278d 55%, #00236f 100%);
  color:#fff;
  position:relative;
  overflow:hidden;
  margin-top:-38px;
}
.marquee-container{
  width:100%;
  overflow:hidden;
  white-space:nowrap;
  position:absolute;
  top:18px;
  left:0;
  opacity:.10;
  pointer-events:none;
}
.marquee{
  display:inline-block;
  animation:marquee 18s linear infinite;
  font-family:'Sora',sans-serif;
  font-size:68px;
  font-weight:800;
  letter-spacing:.08em;
}
@keyframes marquee{
  0%{transform:translateX(0);}
  100%{transform:translateX(-50%);}
}
.resume-top{
  display:grid;
  grid-template-columns:1.08fr 1.12fr;
  gap:28px;
  align-items:stretch;
  margin-top:0;
  margin-bottom:46px;
}
.profile-card,.skill-box{
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.16);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  border-radius:28px;
  box-shadow:var(--shadow);
}
.profile-card{
  padding:30px;
  display:flex;
  gap:24px;
  align-items:center;
  min-height:420px;
}
.photo-wrap{
  position:relative;
  width:340px;
  height:340px;
  flex-shrink:0;
  display:flex;
  align-items:center;
  justify-content:center;
  margin:auto;
}
.personal-photo{
  width:260px;
  height:320px;
  border-radius:999px;
  overflow:hidden;
  background:#fff;
  box-shadow:0 18px 40px rgba(0,0,0,.22);
  position:relative;
  z-index:3;
}
.personal-photo img{
  width:100%;
  height:100%;
  object-fit:cover;
  object-position:center;
  display:block;
  transform:scale(1.08);
}
.personal-text{
  display:flex;
  flex-direction:column;
}
.personal-text h3{
  font-family:'Sora',sans-serif;
  font-size:44px;
  font-weight:800;
  margin-bottom:14px;
  line-height:1;
}
.personal-text p{
  font-size:18px;
  line-height:1.9;
}
.email{
  font-size:16px;
  margin-top:10px;
  opacity:.92;
}
.skill-box{
  padding:30px 32px;
  color:#fff;
}
.skill-box h4{
  font-family:'Sora',sans-serif;
  font-size:26px;
  font-weight:800;
  margin-bottom:18px;
}
.skill-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:14px;
}
.skill-item{
  padding:16px 16px;
  border-radius:18px;
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.10);
}
.skill-item strong{
  display:block;
  font-size:14px;
  letter-spacing:1px;
  margin-bottom:8px;
}
.skill-item span{
  display:block;
  font-size:14px;
  line-height:1.75;
  opacity:.92;
}
.resume-block{margin-top:8px;}
.resume-title{
  display:flex;
  align-items:center;
  gap:14px;
  font-family:'Sora',sans-serif;
  font-size:24px;
  font-weight:700;
  margin:34px 0 22px;
}
.resume-title::before{
  content:"";
  width:42px;
  height:4px;
  border-radius:999px;
  background:linear-gradient(90deg,#fff,rgba(255,255,255,.25));
}
.job-container{
  display:flex;
  flex-direction:column;
  gap:18px;
}
.job-card{
  background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(240,244,255,.93));
  border-radius:24px;
  padding:24px 28px;
  color:#002FA7;
  cursor:pointer;
  transition:.35s ease;
  box-shadow:0 12px 30px rgba(0,0,0,.08);
  border:1px solid rgba(255,255,255,.4);
}
.job-card:hover{
  transform:translateY(-5px);
  box-shadow:0 22px 40px rgba(0,0,0,.12);
}
.job-topline{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:20px;
}
.job-meta{
  font-size:13px;
  letter-spacing:1.3px;
  color:#5771c9;
}
.job-card h4{
  font-family:'Sora',sans-serif;
  font-size:20px;
  line-height:1.4;
  margin-bottom:8px;
}
.job-card p{
  font-size:15px;
  line-height:1.7;
  color:#294baf;
}
.expand-hint{
  color:#8ba0e6;
  font-size:13px;
  white-space:nowrap;
}
.sub-cards{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
  margin-top:14px;
}
.sub-card{
  background:linear-gradient(145deg,#fff,#eef3ff);
  border-radius:18px;
  padding:18px;
  text-align:left;
  color:#002FA7;
  transition:.35s ease;
  border:1px solid rgba(0,47,167,.06);
}
.sub-card:hover{transform:translateY(-4px);}
.icon{font-size:24px;margin-bottom:10px;}
.sub-title{font-size:14px;line-height:1.6;font-weight:500;}

/* 第四页 项目展示 */
.projects-section{
  padding:110px 8% 120px;
  background:#f7f9ff;
  position:relative;
  overflow:hidden;
}
.projects-section::before{
  content:"";
  position:absolute;
  width:520px;
  height:520px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(0,47,167,.08), transparent 70%);
  top:-120px;
  right:-100px;
  filter:blur(10px);
}
.projects-wrap{position:relative;z-index:2;}
.section-page-title{
  text-align:center;
  font-family:'Sora',sans-serif;
  font-weight:800;
  font-size:clamp(28px,4vw,44px);
  color:var(--blue);
  margin-bottom:16px;
}
.section-page-sub{
  text-align:center;
  color:#5f709c;
  font-size:15px;
  line-height:1.8;
  max-width:760px;
  margin:0 auto 44px;
}
.slides-container{
  position:relative;
  height:610px;
  display:flex;
  justify-content:center;
  align-items:center;
  overflow:hidden;
}
.slide-card{
  background:#002FA7;
  border-radius:28px;
  width:280px;
  height:430px;
  position:absolute;
  top:50%;
  color:#fff;
  box-shadow:0 18px 40px rgba(0,0,0,0.18);
  transition:all .5s ease;
  cursor:pointer;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.12);
}
.slide-card::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(180deg,rgba(255,255,255,0) 20%,rgba(0,0,0,.10) 48%,rgba(0,18,78,.70) 100%);
  z-index:1;
}
.card-cover{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  object-position:center;
}
.card-content{
  position:absolute;
  left:0;
  right:0;
  bottom:0;
  z-index:2;
  padding:22px 20px 22px;
}
.slide-card .card-number{
  position:absolute;
  top:16px;
  right:16px;
  font-family:'Sora',sans-serif;
  font-size:18px;
  font-weight:800;
  letter-spacing:.08em;
  opacity:.75;
  z-index:2;
}
.slide-card .card-tag{
  display:inline-flex;
  font-size:11px;
  letter-spacing:1.8px;
  text-transform:uppercase;
  padding:7px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.14);
  backdrop-filter:blur(6px);
  margin-bottom:12px;
}
.slide-card .card-title{
  font-family:'Sora',sans-serif;
  font-size:22px;
  font-weight:700;
  line-height:1.3;
}
.slide-arrow{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  font-size:32px;
  color:#002FA7;
  background:#fff;
  border-radius:50%;
  width:54px;
  height:54px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  z-index:100;
  box-shadow:0 12px 25px rgba(0,0,0,0.12);
  user-select:none;
}
.slide-arrow.left{left:0;}
.slide-arrow.right{right:0;}

/* 第五页 内容运营 */
.content-section{
  padding:110px 8% 120px;
  background:#fff;
  position:relative;
}
.content-intro{
  text-align:center;
  color:#5f709c;
  font-size:15px;
  line-height:1.8;
  max-width:760px;
  margin:0 auto 50px;
}
.magazine-grid{
  column-count:3;
  column-gap:22px;
}
.mag-card{
  break-inside:avoid;
  margin-bottom:22px;
  display:block;
  text-decoration:none;
  background:#fff;
  border:1px solid rgba(0,47,167,.08);
  border-radius:24px;
  overflow:hidden;
  box-shadow:0 10px 24px rgba(0,47,167,.05);
  transition:.35s ease;
}
.mag-card:hover{
  transform:translateY(-6px);
  box-shadow:0 18px 36px rgba(0,47,167,.10);
}
.mag-cover{
  width:100%;
  display:block;
  object-fit:cover;
  object-position:center;
  background:#eef3ff;
}
.mag-card.tall .mag-cover{aspect-ratio:4/6;}
.mag-card.medium .mag-cover{aspect-ratio:4/5;}
.mag-card.short .mag-cover{aspect-ratio:4/4.3;}
.mag-info{
  padding:18px 18px 20px;
}
.mag-index{
  display:inline-block;
  font-size:11px;
  letter-spacing:1.6px;
  text-transform:uppercase;
  color:#6f84c8;
  margin-bottom:8px;
}
.mag-title{
  font-family:'Sora',sans-serif;
  color:var(--blue);
  font-size:18px;
  line-height:1.55;
  margin-bottom:10px;
}
.mag-desc{
  color:#60719d;
  line-height:1.8;
  font-size:14px;
}

/* 第六页 会徽设计 */
.other-works-section{
  padding:110px 8% 120px;
  background:
    radial-gradient(circle at 20% 20%, rgba(0,47,167,.06), transparent 22%),
    radial-gradient(circle at 80% 10%, rgba(0,47,167,.05), transparent 18%),
    #f7f9ff;
  position:relative;
  overflow:hidden;
}
.logo-proposal-wrap{position:relative;z-index:2;}
.logo-hero-card{
  position:relative;
  display:grid;
  grid-template-columns:1.15fr .85fr;
  gap:28px;
  align-items:stretch;
  padding:26px;
  border-radius:32px;
  background:rgba(255,255,255,.72);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  border:1px solid rgba(0,47,167,.08);
  box-shadow:0 18px 40px rgba(0,47,167,.08);
  overflow:hidden;
  cursor:pointer;
  transition:transform .45s ease, box-shadow .45s ease, border-color .45s ease;
}
.logo-hero-card:hover{
  transform:translateY(-6px);
  box-shadow:0 24px 60px rgba(0,47,167,.14);
  border-color:rgba(0,47,167,.16);
}
.logo-hero-glow{
  position:absolute;
  width:420px;
  height:420px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(0,47,167,.14), rgba(0,47,167,0) 70%);
  right:-60px;
  top:-80px;
  filter:blur(20px);
  pointer-events:none;
}
.logo-hero-img{
  width:100%;
  height:100%;
  min-height:420px;
  object-fit:cover;
  object-position:center;
  border-radius:24px;
  box-shadow:0 12px 30px rgba(0,0,0,.08);
  transition:transform .6s ease;
}
.logo-hero-card:hover .logo-hero-img{transform:scale(1.02);}
.logo-hero-info{
  display:flex;
  flex-direction:column;
  justify-content:center;
  padding:10px 6px;
}
.logo-hero-tag{
  display:inline-flex;
  align-self:flex-start;
  padding:8px 12px;
  border-radius:999px;
  background:rgba(0,47,167,.08);
  color:var(--blue);
  font-size:12px;
  letter-spacing:1.5px;
  text-transform:uppercase;
  margin-bottom:16px;
}
.logo-hero-info h3{
  font-family:'Sora',sans-serif;
  color:var(--blue);
  font-size:32px;
  line-height:1.3;
  margin-bottom:16px;
}
.logo-hero-info p{
  color:#5d6f9e;
  font-size:15px;
  line-height:1.9;
  margin-bottom:22px;
}
.logo-open-btn{
  width:max-content;
  border:none;
  background:var(--blue);
  color:#fff;
  border-radius:999px;
  padding:14px 22px;
  font-size:14px;
  cursor:pointer;
  transition:transform .3s ease, background .3s ease;
}
.logo-open-btn:hover{
  transform:translateY(-2px);
  background:#001f78;
}

/* 通用弹窗 */
#slide-popup{
  display:none;
  position:fixed;
  top:0;left:0;
  width:100%;height:100%;
  background:rgba(2,12,45,0.68);
  z-index:1200;
  justify-content:center;
  align-items:center;
  padding:20px;
}
#slide-popup .popup-content{
  width:min(1200px,100%);
  height:min(90vh,860px);
  overflow:hidden;
  background:rgba(255,255,255,.08);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-radius:28px;
  border:1px solid rgba(255,255,255,.2);
  position:relative;
  box-shadow:0 24px 80px rgba(0,0,0,.28);
  display:flex;
  justify-content:center;
  align-items:center;
}
#slide-popup .popup-close{
  position:absolute;
  top:16px;
  right:18px;
  font-size:32px;
  cursor:pointer;
  font-weight:bold;
  z-index:60;
  color:#fff;
  line-height:1;
}
#popup-carousel{
  position:relative;
  width:100%;
  height:100%;
  overflow:hidden;
}
#popup-carousel .carousel-inner{
  display:flex;
  transition:transform 0.5s ease;
  height:100%;
}
#popup-carousel img{
  width:100%;
  flex-shrink:0;
  object-fit:contain;
  height:100%;
  padding:54px 34px 30px;
}
.carousel-arrow{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  font-size:30px;
  color:#002FA7;
  background:#fff;
  border-radius:50%;
  width:50px;
  height:50px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  z-index:50;
  box-shadow:0 10px 24px rgba(0,0,0,.12);
}
.left-arrow{left:14px;}
.right-arrow{right:14px;}

.footer-note{
  padding:26px 8% 40px;
  background:#fff;
  color:#6c7aa8;
  font-size:13px;
  letter-spacing:1.2px;
}

@media(max-width:1100px){
  .resume-top{grid-template-columns:1fr;}
  .sub-cards{grid-template-columns:repeat(2,1fr);}
  .magazine-grid{column-count:2;}
