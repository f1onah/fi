// 第一屏粒子
(function(){
  const wrap = document.getElementById('heroParticleWrap');
  const canvas = document.getElementById('heroParticleCanvas');
  const ctx = canvas.getContext('2d');
  const title = document.getElementById('heroTitle');
  const wordEl = title.querySelector('.title-word');
  if(!wrap || !canvas || !ctx || !wordEl) return;

  let dpr = Math.min(window.devicePixelRatio || 1, 2);
  let particles = [];
  let mouse = { x: null, y: null, active: false };
  let lastScatterTime = 0;

  function resizeCanvas(){
    const rect = wrap.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    ctx.setTransform(dpr,0,0,dpr,0,0);
    buildParticles();
  }

  function buildParticles(){
    particles = [];
    const wrapRect = wrap.getBoundingClientRect();
    const wordRect = wordEl.getBoundingClientRect();

    const areaX = wordRect.left - wrapRect.left;
    const areaY = wordRect.top - wrapRect.top;
    const areaW = wordRect.width;
    const areaH = wordRect.height;

    const expandX = Math.max(120, areaW * 0.16);
    const expandY = Math.max(70, areaH * 0.7);

    const startX = areaX - expandX;
    const startY = areaY - expandY;
    const fullW = areaW + expandX * 2;
    const fullH = areaH + expandY * 2;

    const count = Math.max(260, Math.floor(fullW * fullH / 2400));

    for(let i=0;i<count;i++){
      const px = startX + Math.random() * fullW;
      const py = startY + Math.random() * fullH;
      const nx = (px - (areaX + areaW/2)) / (fullW/2);
      const ny = (py - (areaY + areaH/2)) / (fullH/2);
      const dist = Math.sqrt(nx*nx + ny*ny);
      if(Math.random() < dist * 0.28) continue;

      const edgeBias = Math.random();
      particles.push({
        x:px,y:py,ox:px,oy:py,
        vx:(Math.random() - 0.5) * 0.3,
        vy:(Math.random() - 0.5) * 0.3,
        size: edgeBias > 0.72 ? Math.random() * 3.2 + 1.2 : Math.random() * 2 + 0.5,
        alpha: edgeBias > 0.72 ? Math.random() * 0.45 + 0.18 : Math.random() * 0.22 + 0.08,
        phase:Math.random() * Math.PI * 2,
        drift:Math.random() * 0.9 + 0.2,
        edge: edgeBias > 0.72
      });
    }
  }

  function scatter(boost = 1){
    const now = Date.now();
    if(now - lastScatterTime < 100) return;
    lastScatterTime = now;
    particles.forEach(p=>{
      const angle = Math.random() * Math.PI * 2;
      const force = (Math.random() * 3 + 1.2) * boost * (p.edge ? 1.35 : 1);
      p.vx += Math.cos(angle) * force;
      p.vy += Math.sin(angle) * force;
    });
  }

  function update(){
    const rect = wrap.getBoundingClientRect();
    ctx.clearRect(0,0,rect.width,rect.height);

    particles.forEach((p,i)=>{
      p.phase += 0.018;
      const floatX = Math.cos(p.phase + i * 0.2) * 0.12 * p.drift;
      const floatY = Math.sin(p.phase * 1.2 + i * 0.15) * 0.12 * p.drift;

      p.vx += (p.ox - p.x) * 0.008;
      p.vy += (p.oy - p.y) * 0.008;
      p.vx *= 0.945;
      p.vy *= 0.945;

      if(mouse.active && mouse.x !== null && mouse.y !== null){
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        const radius = 150;
        if(dist < radius && dist > 0.001){
          const force = (1 - dist / radius) * (p.edge ? 2.3 : 1.4);
          p.vx += (dx / dist) * force;
          p.vy += (dy / dist) * force;
        }
      }

      p.x += p.vx + floatX;
      p.y += p.vy + floatY;

      ctx.beginPath();
      ctx.fillStyle = `rgba(0,47,167,${p.alpha})`;
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fill();

      if(p.edge){
        ctx.beginPath();
        ctx.fillStyle = `rgba(0,47,167,${p.alpha * 0.12})`;
        ctx.arc(p.x, p.y, p.size * 2.4, 0, Math.PI * 2);
        ctx.fill();
      }
    });

    requestAnimationFrame(update);
  }

  wrap.addEventListener('mouseenter', ()=>{
    wrap.classList.add('active');
    scatter(1.8);
  });
  wrap.addEventListener('mouseleave', ()=>{
    wrap.classList.remove('active');
    mouse.active = false;
    mouse.x = null;
    mouse.y = null;
  });
  wrap.addEventListener('mousemove', (e)=>{
    const rect = wrap.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
    mouse.active = true;
  });
  wrap.addEventListener('click', ()=>{ scatter(2.5); });
  window.addEventListener('resize', resizeCanvas);

  resizeCanvas();
  update();
  setTimeout(()=>scatter(1.2), 250);
})();
</script>
